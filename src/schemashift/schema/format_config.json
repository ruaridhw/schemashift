{
  "$defs": {
    "ColumnConstraints": {
      "description": "Per-column schema definition mapping to a dataframely column type + constraints.",
      "properties": {
        "description": {
          "default": "",
          "description": "Human-readable description.",
          "title": "Description",
          "type": "string"
        },
        "is_in": {
          "anyOf": [
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Allowed values (integers only natively; strings use check).",
          "title": "Is In"
        },
        "max": {
          "default": null,
          "description": "Maximum value (inclusive).",
          "title": "Max"
        },
        "max_exclusive": {
          "default": null,
          "description": "Maximum value (exclusive).",
          "title": "Max Exclusive"
        },
        "max_length": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum string length.",
          "title": "Max Length"
        },
        "min": {
          "default": null,
          "description": "Minimum value (inclusive).",
          "title": "Min"
        },
        "min_exclusive": {
          "default": null,
          "description": "Minimum value (exclusive).",
          "title": "Min Exclusive"
        },
        "min_length": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Minimum string length.",
          "title": "Min Length"
        },
        "nullable": {
          "default": false,
          "description": "Whether null values are allowed.",
          "title": "Nullable",
          "type": "boolean"
        },
        "primary_key": {
          "default": false,
          "description": "Whether this column is a primary key.",
          "title": "Primary Key",
          "type": "boolean"
        },
        "regex": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Regex pattern the string must match.",
          "title": "Regex"
        },
        "type": {
          "description": "Polars dtype string (e.g. 'int64', 'str', 'float64').",
          "enum": [
            "str",
            "string",
            "utf8",
            "int8",
            "int16",
            "int32",
            "int64",
            "integer",
            "uint8",
            "uint16",
            "uint32",
            "uint64",
            "float32",
            "float64",
            "number",
            "bool",
            "boolean",
            "date",
            "datetime",
            "time",
            "duration",
            "binary",
            "categorical",
            "null"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "ColumnConstraints",
      "type": "object"
    },
    "ColumnMapping": {
      "description": "Describes how to produce one output column.",
      "properties": {
        "constant": {
          "description": "Literal constant broadcast to all rows. Mutually exclusive with 'source' and 'expr'.",
          "title": "Constant"
        },
        "dtype": {
          "anyOf": [
            {
              "enum": [
                "binary",
                "bool",
                "boolean",
                "categorical",
                "date",
                "datetime",
                "duration",
                "float32",
                "float64",
                "int16",
                "int32",
                "int64",
                "int8",
                "integer",
                "null",
                "number",
                "str",
                "string",
                "time",
                "uint16",
                "uint32",
                "uint64",
                "uint8",
                "utf8"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Target Polars dtype to cast this column to after mapping.",
          "title": "Dtype"
        },
        "expr": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "DSL expression to compute this column (e.g. col(\"price\") * 1.2). Mutually exclusive with 'source' and 'constant'.",
          "title": "Expr"
        },
        "fillna": {
          "description": "Fill-value applied to nulls after mapping.",
          "title": "Fillna"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Source column name in the input file. Mutually exclusive with 'expr' and 'constant'.",
          "title": "Source"
        },
        "target": {
          "description": "Name of the output column produced by this mapping.",
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "target"
      ],
      "title": "ColumnMapping",
      "type": "object"
    },
    "ReaderConfig": {
      "description": "Low-level options passed to the file reader.",
      "properties": {
        "encoding": {
          "default": "utf-8",
          "description": "Character encoding of the source file.",
          "title": "Encoding",
          "type": "string"
        },
        "separator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CSV field delimiter. Auto-detected when null.",
          "title": "Separator"
        },
        "sheet_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Excel sheet name (string) or 0-based index (int). Ignored for non-Excel files.",
          "title": "Sheet Name"
        },
        "skip_rows": {
          "default": 0,
          "description": "Number of rows to skip before the header.",
          "minimum": 0,
          "title": "Skip Rows",
          "type": "integer"
        }
      },
      "title": "ReaderConfig",
      "type": "object"
    },
    "SchemaConfig": {
      "description": "Declarative schema definition loadable from YAML/JSON.",
      "properties": {
        "columns": {
          "additionalProperties": {
            "$ref": "#/$defs/ColumnConstraints"
          },
          "description": "Column name \u2192 constraints mapping.",
          "title": "Columns",
          "type": "object"
        },
        "description": {
          "default": "",
          "description": "Human-readable description.",
          "title": "Description",
          "type": "string"
        },
        "name": {
          "description": "Schema identifier.",
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name",
        "columns"
      ],
      "title": "SchemaConfig",
      "type": "object"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Top-level specification for a declarative transformation pipeline.",
  "properties": {
    "columns": {
      "description": "Ordered list of column mappings defining the output schema.",
      "items": {
        "$ref": "#/$defs/ColumnMapping"
      },
      "title": "Columns",
      "type": "array"
    },
    "description": {
      "default": "",
      "description": "Human-readable description of this transform.",
      "title": "Description",
      "type": "string"
    },
    "drop_unmapped": {
      "default": true,
      "description": "Drop source columns not referenced by any mapping.",
      "title": "Drop Unmapped",
      "type": "boolean"
    },
    "name": {
      "description": "Unique identifier for this transform specification.",
      "title": "Name",
      "type": "string"
    },
    "output_schema": {
      "anyOf": [
        {
          "$ref": "#/$defs/SchemaConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Output schema for validation via dataframely."
    },
    "reader": {
      "$ref": "#/$defs/ReaderConfig",
      "description": "Low-level reader options."
    },
    "version": {
      "default": 1,
      "description": "Spec version. Increment on breaking changes.",
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "name",
    "columns"
  ],
  "title": "TransformSpec",
  "type": "object"
}